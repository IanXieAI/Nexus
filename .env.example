# Copy this file to .env and fill in your values.
# Never commit the .env file — it is already listed in .gitignore.

# RPC endpoints (e.g. Alchemy, Infura, or your own node)
SEPOLIA_RPC_URL=
MAINNET_RPC_URL=

# Private key of the deploying wallet (without 0x prefix)
DEPLOYER_PRIVATE_KEY=

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Set to "true" to enable gas cost reporting during tests
REPORT_GAS=false
